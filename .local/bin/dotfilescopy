#!/bin/bash
pretty=1 # whether to log commands being executed or not.
dotfiles=".zshenv .local/bin .config/vim .config/fontconfig .config/x11 .config/zsh .config/user-dirs.dirs"
repo="$HOME/.local/src/rice"

[ "$pretty" -lt 1 ] && {
	set -x
};

command -v rsync || exit 1
for d in $dotfiles; do
	rsync -avR --delete --force "$HOME/./$d" "$repo"
done
