#!/bin/sh

if [ "$1" == "--session" ]; then
	[ -n "$2" ] || exit 1
	name="$2"
	dir="$PWD"
else
	name="$(basename "$1")"
	dir="$1"
fi

if tmux has-session -t "$name" 2>/dev/null; then
	if [ -n "$TMUX" ]; then
		tmux switch-client -t "$name"
	else
		tmux attach-session -t "$name"
	fi
else
	if [ -n "$TMUX" ]; then
		tmux new-session -ds "$name" -c "$dir"
		tmux switch-client -t "$name"
	else
		tmux new-session -s "$name" -c "$dir"
	fi
fi
