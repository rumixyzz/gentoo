#!/bin/sh
BAT="BAT0"
capacity="$(cat /sys/class/power_supply/"$BAT"/capacity)"

case $capacity in
    100) icon="σΑ¹Ι" ;;
    9[0-9]) icon="σΑ²²" ;;
    8[0-9]) icon="σΑ²¹" ;;
    7[0-9]) icon="σΑ²Ä" ;;
    6[0-9]) icon="σΑ¹Ω" ;;
    5[0-9]) icon="σΑ¹Ψ" ;;
    4[0-9]) icon="σΑ¹Ϋ" ;;
    3[0-9]) icon="σΑ¹Φ" ;;
    2[0-9]) icon="σΑ¹Μ" ;;
    1[0-9]) icon="σΑ¹Κ" ;;
    [0-9])  icon="σΑ²é" ;;
esac

printf "%s%%" "$icon $capacity"
