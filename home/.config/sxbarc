# layout and style
bottom_bar          : false
height              : 20
vertical_padding    : 0
horizontal_padding  : 0
text_padding        : 0
border              : false
border_width        : 2
background_colour   : #0c0d0e
foreground_colour   : #b7b8b9
border_colour       : #75857B
font                : monospace 
font_size           : 18

# modules

module.0.name       : volume
module.0.cmd        : sb-vol
module.0.enabled    : true
module.0.interval   : 1

module.1.name       : battery
module.1.cmd        : sb-bat
module.1.enabled    : true
module.1.interval   : 15

module.2.name       : date
module.2.cmd        : sb-date
module.2.enabled    : true
module.2.interval   : 1

workspaces.labels              : web term build mus misc tmp obs
workspaces.active_background   : #0c0d0e
workspaces.active_foreground   : #e31a1c
workspaces.inactive_background : #0c0d0e
workspaces.inactive_foreground : #b7b8b9
workspaces.padding_left        : 10
workspaces.padding_right       : 10
workspaces.spacing             : 0
workspaces.position            : left
